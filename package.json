{
  "name": "mylog-desktop-notifier",
  "version": "1.0.0",
  "description": "MyLog 桌面通知代理 - 系统级来电/消息提醒",
  "main": "main.js",
  "scripts": {
    "dev": "scripts\\start.bat",
    "build": "node build.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "com.mylog.desktop-notifier",
    "productName": "MyLog通知助手",
    "copyright": "Copyright © 2025 MyLog",
    "asar": false,
    "directories": {
      "output": "dist-installer"
    },
    "files": [
      "main.js",
      "config.js",
      "src/**/*",
      "assets/**/*",
      "package.json",
      "node_modules/**/*",
      "!node_modules/**/electron/dist/**",
      "!node_modules/**/*.md",
      "!node_modules/**/*.ts",
      "!**/.git/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MyLog通知助手",
      "runAfterFinish": false,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    }
  },
  "dependencies": {
    "jimp": "^0.22.12",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^32.3.3",
    "electron-builder": "^25.0.0"
  }
}
