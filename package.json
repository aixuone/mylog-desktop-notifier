{
  "name": "mylog-desktop-notifier",
  "version": "1.0.0",
  "description": "MyLog 桌面通知代理 - 系统级来电/消息提醒",
  "main": "main.js",
  "scripts": {
    "dev": "scripts\\start.bat",
    "dev:mac": "bash scripts/start.sh",
    "build": "node build.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:all": "electron-builder --win --mac"
  },
  "build": {
    "appId": "com.mylog.desktop-notifier",
    "productName": "MyLogNotifier",
    "copyright": "Copyright (c) 2025 MyLog",
    "asar": true,
    "asarUnpack": [
      "assets/**/*"
    ],
    "directories": {
      "output": "dist-installer-new"
    },
    "files": [
      "main.js",
      "config.js",
      "src/**/*",
      "assets/**/*",
      "package.json",
      "node_modules/**/*",
      "!node_modules/**/electron/dist/**",
      "!node_modules/**/*.md",
      "!node_modules/**/*.ts",
      "!**/.git/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "assets/icon.png",
      "category": "public.app-category.utilities",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "LSUIElement": true,
        "NSHighResolutionCapable": true
      }
    },
    "dmg": {
      "title": "MyLog Notifier",
      "icon": "assets/icon.png",
      "iconSize": 80,
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MyLog Notifier",
      "runAfterFinish": false,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    }
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^32.3.3",
    "electron-builder": "^25.1.8",
    "jimp": "^0.22.12"
  }
}
